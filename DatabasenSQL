-- Roller & Behörigheter
-- OBS: Kräver att den som kör skriptet får skapa roller

DO $$
BEGIN
    IF NOT EXISTS (SELECT 1 FROM pg_roles WHERE rolname = 'pizzeria_admin') THEN
        CREATE ROLE pizzeria_admin;
    END IF;

    IF NOT EXISTS (SELECT 1 FROM pg_roles WHERE rolname = 'pizzeria_anstalld') THEN
        CREATE ROLE pizzeria_anstalld;
    END IF;

    IF NOT EXISTS (SELECT 1 FROM pg_roles WHERE rolname = 'pizzeria_las') THEN
        CREATE ROLE pizzeria_las;
    END IF;
END;
$$;


-- Våra RBAC (Role Based Access Control) alltså vilka roller som har rätt till vilken data i databasen. Exempelvis att anställda ska enbart kunna uppdatera produktinformation men inte kunduppgifter.
GRANT USAGE ON SCHEMA public TO pizzeria_admin, pizzeria_anstalld, pizzeria_las;

GRANT SELECT ON ALL TABLES IN SCHEMA public TO pizzeria_las;

GRANT SELECT ON ALL TABLES IN SCHEMA public TO pizzeria_anstalld;
GRANT UPDATE (Beskrivning) ON Produkter TO pizzeria_anstalld;

GRANT SELECT, INSERT, UPDATE, DELETE ON ALL TABLES IN SCHEMA public TO pizzeria_admin;
GRANT USAGE, SELECT ON ALL SEQUENCES IN SCHEMA public TO pizzeria_admin;

REVOKE UPDATE, DELETE ON Produkter FROM PUBLIC;

ALTER DEFAULT PRIVILEGES IN SCHEMA public GRANT SELECT ON TABLES TO pizzeria_las;
ALTER DEFAULT PRIVILEGES IN SCHEMA public GRANT SELECT ON TABLES TO pizzeria_anstalld;
ALTER DEFAULT PRIVILEGES IN SCHEMA public GRANT SELECT, INSERT, UPDATE, DELETE ON TABLES TO pizzeria_admin;



-- Exempel på frågor
-- JOIN + GROUP BY för att få fram totalförsäljning per produkttyp.
SELECT pt.ProduktTypNamn, SUM(o.Antal * p.Pris) AS total_forsaljning
FROM Orderrader o
JOIN Produkter p ON o.ProduktID = p.ProduktID
JOIN Produkttyp pt ON p.ProduktTypID = pt.ProduktTypID
GROUP BY pt.ProduktTypNamn
ORDER BY total_forsaljning DESC;



-- JOIN + GROUP BY för att få kunder baserat på antal ordrar.
SELECT k.Namn, COUNT(b.OrderID) AS antal_orders, SUM(b.Totalbelopp) AS totalt_spenderat
FROM Kunder k
JOIN Bestallningar b ON k.KundID = b.KundID
GROUP BY k.Namn
ORDER BY totalt_spenderat DESC;



