-- VY FÖR ORDERSAMMANFATTNING (KVITTO)
DROP VIEW IF EXISTS OrdersammanFattning;

CREATE VIEW OrdersammanFattning AS
SELECT 
    Bestallningar.OrderID               AS KvittoNummer,
    Bestallningar.Datum                 AS OrderDatum,
    Kunder.Namn                         AS KundNamn,
    Produkter.ProduktNamn               AS ProduktNamn,
    Orderrader.Antal                    AS Antal,
    Produkter.Pris                      AS Pris,
    (Orderrader.Antal * Produkter.Pris) AS RadSumma,
    Bestallningar.Totalbelopp           AS TotalBelopp
FROM Bestallningar
JOIN Kunder     ON Bestallningar.KundID  = Kunder.KundID
JOIN Orderrader ON Bestallningar.OrderID = Orderrader.OrderID
JOIN Produkter  ON Orderrader.ProduktID  = Produkter.ProduktID;

