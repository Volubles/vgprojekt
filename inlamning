CREATE TABLE Kunder (
    KundID SERIAL PRIMARY KEY,
    Namn VARCHAR(100) NOT NULL,
    Email VARCHAR(255) UNIQUE NOT NULL,
    Telefon VARCHAR(30) NOT NULL,
    Adress VARCHAR(100) NOT NULL,
	Losenord VARCHAR(100) NOT NULL
);

CREATE TABLE Kundlogg (
    LoggID INT AUTO_INCREMENT PRIMARY KEY,
    KundID INT, 
    Handelse VARCHAR(255),
    Loggdatum TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    FOREIGN KEY (KundID) REFERENCES Kunder(KundID) ON DELETE SET NULL
);

CREATE TABLE Produkttyp (
    ProduktTypID INT PRIMARY KEY,
    ProduktTypNamn VARCHAR(100) NOT NULL
);

CREATE TABLE Produkter (
    ProduktID SERIAL PRIMARY KEY, -- Tillagd AUTO_INCREMENT
    ProduktTypID INT NOT NULL,
    ProduktNamn VARCHAR(40) NOT NULL UNIQUE,
    Pris DECIMAL(14,2) NOT NULL CHECK (Pris > 0),
    FOREIGN KEY (ProduktTypID) REFERENCES Produkttyp(ProduktTypID)
);

CREATE TABLE Bestallningar (
    OrderID INT PRIMARY KEY,
    KundID INT NOT NULL,
    Totalbelopp DECIMAL(10,2) NOT NULL CHECK (Totalbelopp > 0),
    Datum TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    FOREIGN KEY (KundID) REFERENCES Kunder(KundID)
);

CREATE TABLE Orderrader (
    OrderradID SERIAL PRIMARY KEY, -- Tillagd AUTO_INCREMENT
    OrderID INT NOT NULL,
    ProduktID INT NOT NULL,
    Antal INT NOT NULL CHECK (Antal > 0),
    FOREIGN KEY (OrderID) REFERENCES Bestallningar(OrderID),
    FOREIGN KEY (ProduktID) REFERENCES Produkter(ProduktID)
);

CREATE OR REPLACE FUNCTION logga_ny_kund()
RETURNS TRIGGER AS $$
BEGIN
    INSERT INTO Kundlogg (KundID)
    VALUES (NEW.KundID);
    RETURN NEW;
END;
$$ LANGUAGE plpgsql;

CREATE TRIGGER trigger_logga_ny_kund
AFTER INSERT ON Kunder
FOR EACH ROW
EXECUTE FUNCTION logga_ny_kund();

CREATE OR REPLACE FUNCTION logga_kund_uppdatering()
RETURNS TRIGGER AS $$
BEGIN
    INSERT INTO Kundlogg (KundID)
    VALUES (NEW.KundID);
    RETURN NEW;
END;
$$ LANGUAGE plpgsql;

CREATE TRIGGER trigger_kund_uppdatering
AFTER UPDATE ON Kunder
FOR EACH ROW
EXECUTE FUNCTION logga_kund_uppdatering();



-- 2. Skapa funktionen som triggern ska använda
CREATE OR REPLACE FUNCTION formatera_email()
RETURNS TRIGGER AS $$
BEGIN
    -- Ändrar e-postadressen till små bokstäver
    NEW.Email = LOWER(NEW.Email);
    RETURN NEW;
END;
$$ LANGUAGE plpgsql;

-- 3. Skapa triggern som kör funktionen innan varje ny kund eller uppdatering
CREATE TRIGGER trigger_formatera_email
BEFORE INSERT OR UPDATE ON Kunder
FOR EACH ROW
EXECUTE FUNCTION formatera_email();



